<header class="site-header" role="banner">
  <div class="container">
    <div class="site-header-inner">
      <div class="site-header-top">
        {{#is "home"}}<h1 class="site-logo">{{else}}<div class="site-logo">{{/is}}
        {{#if @site.logo}}
          <a href="{{@site.url}}">
            <img src="{{@site.logo}}" alt="{{@site.title}}" />
          </a>
        {{else}}
          <a href="{{@site.url}}">{{@site.title}}</a>
        {{/if}}
        {{#is "home"}}</h1>{{else}}</div>{{/is}}
        <div class="site-header-actions">
          <button class="search-icon-btn" data-ghost-search type="button" aria-label="{{t "Search"}}">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/>
              <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          </button>
          {{#if @site.members_enabled}}
            {{#unless @member}}
              <a class="subscribe-icon-btn" id="nav-subscribe" href="{{@site.url}}/#/portal/signup" aria-label="{{t "Subscribe"}}">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/>
                  <path d="M4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/>
                </svg>
              </a>
            {{/unless}}
            {{#if @member}}
              <a class="subscribe-icon-btn" id="nav-subscribe" href="{{@site.url}}/#/portal/account" aria-label="{{t "Account"}}">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/>
                  <path d="M4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/>
                </svg>
              </a>
            {{/if}}
          {{/if}}
          <button class="theme-toggle" data-theme-toggle type="button" aria-label="{{t "Toggle theme"}}">
            <span class="icon-sun" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="5"/>
                <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
              </svg>
            </span>
            <span class="icon-moon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
              </svg>
            </span>
          </button>
        </div>
      </div>

      {{#if @site.description}}
        <p class="site-description">{{@site.description}}</p>
      {{/if}}

      <nav class="site-nav" role="navigation" aria-label="{{t "Primary navigation"}}">
        {{navigation type="primary"}}
        <div class="nav-more" data-nav-more>
          <button class="nav-more-toggle" type="button" aria-label="{{t "More"}}" aria-expanded="false">
            {{t "More"}} <span class="nav-more-arrow" aria-hidden="true">&#9662;</span>
          </button>
          <div class="nav-more-dropdown" data-nav-dropdown></div>
        </div>
      </nav>
    </div>
  </div>
</header>
