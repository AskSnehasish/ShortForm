<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="site-footer-copyright">
      &copy; {{date format="YYYY"}} <a href="{{@site.url}}">{{@site.title}}</a>. {{t "All rights reserved."}}
    </div>
    <nav class="site-footer-nav" aria-label="{{t "Footer navigation"}}">
      <a href="{{@site.url}}/rss/" aria-label="{{t "RSS Feed"}}">{{t "RSS"}}</a>
      {{#if @site.facebook}}<span class="sep" aria-hidden="true">&middot;</span>
        <a href="{{@site.facebook}}" target="_blank" rel="noopener noreferrer" aria-label="{{t "Facebook"}}">{{t "Facebook"}}</a>
      {{/if}}
      {{#if @site.twitter}}<span class="sep" aria-hidden="true">&middot;</span>
        <a href="{{@site.twitter}}" target="_blank" rel="noopener noreferrer" aria-label="{{t "Twitter"}}">{{t "Twitter"}}</a>
      {{/if}}
    </nav>
  </div>
</footer>
