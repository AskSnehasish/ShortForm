<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="site-footer-copyright">
      {{#if @custom.copyright_text}}{{@custom.copyright_text}}{{else}}&copy; {{date format="YYYY"}} <a href="{{@site.url}}">{{@site.title}}</a>.{{/if}}
    </div>
    <nav class="site-footer-nav" aria-label="{{t "Footer"}}">
      <a href="{{@site.url}}/rss/">{{t "RSS"}}</a>
      {{#social_accounts @site}}
        <span class="sep" aria-hidden="true">·</span>
        <a href="{{href}}" target="_blank" rel="noopener noreferrer">{{name}}</a>
      {{/social_accounts}}
    </nav>
    {{#if @custom.show_credit_line}}
      <p class="site-footer-credit">Designed with ❤️ in India by <a href="https://snayak.com" target="_blank" rel="noopener noreferrer">Snehasish</a>.</p>
    {{/if}}
  </div>
</footer>
