<article class="post-full reveal" role="article">
  <header class="post-header">
    <h2 class="post-full-title"><a href="{{url}}">{{title}}</a></h2>
    {{#if custom_excerpt}}
      <p class="post-excerpt">{{custom_excerpt}}</p>
    {{/if}}
    <div class="post-meta">
      <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMM D, YYYY"}}</time>
      <span class="sep" aria-hidden="true">&middot;</span>
      <span>{{reading_time minute=(t "1 min read") minutes=(t "% min read")}}</span>
      {{#if primary_tag}}
        <span class="sep" aria-hidden="true">&middot;</span>
        <a class="post-tag" href="{{primary_tag.url}}">{{primary_tag.name}}</a>
      {{/if}}
    </div>
  </header>

  {{#if feature_image}}
    {{#if @custom.show_featured_image}}
      <figure class="featured-image">
        <a href="{{url}}">
          <img src="{{img_url feature_image size="lg"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy" />
        </a>
      </figure>
    {{/if}}
  {{/if}}

  <div class="post-content">{{content}}</div>
</article>
{{#if @last}}{{else}}<hr class="post-sep" aria-hidden="true">{{/if}}