{{!< default}}

{{#post}}
<article class="post-content container" role="article" itemscope itemtype="https://schema.org/Article">
  <header class="post-header">
    <h1 class="post-full-title" itemprop="headline">{{title}}</h1>
    {{#if custom_excerpt}}
      <p class="post-excerpt" itemprop="description">{{custom_excerpt}}</p>
    {{/if}}

    <div class="post-meta">
      <time datetime="{{date format="YYYY-MM-DD"}}" itemprop="datePublished">{{date format="MMM D, YYYY"}}</time>
      <span class="sep" aria-hidden="true">&middot;</span>
      <span>{{reading_time minute=(t "1 min read") minutes=(t "% min read")}}</span>
    </div>
  </header>

  {{#if feature_image}}
    {{#if @custom.show_featured_image}}
      <figure class="featured-image">
        <img src="{{img_url feature_image size="xl"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" />
        {{#if feature_image_caption}}
          <figcaption>{{{feature_image_caption}}}</figcaption>
        {{else if feature_image_alt}}
          <figcaption>{{feature_image_alt}}</figcaption>
        {{/if}}
      </figure>
    {{/if}}
  {{/if}}

  {{> "toc"}}

  <div class="post-content" itemprop="articleBody">
    {{content}}
  </div>

  {{> "author-box"}}

  {{> "newsletter"}}
  
</article>
{{/post}}
