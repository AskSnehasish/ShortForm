{{!< default}}

<div class="container">
  <article class="post-content" style="max-width: 480px; margin: 0 auto;">
    <h1>{{t "Sign in"}}</h1>
    <p class="text-muted" style="margin-bottom: var(--space-4);">{{t "Welcome back. Sign in to your account."}}</p>

    {{#if @member}}
      <p>{{t "You are already signed in."}} <a href="{{@site.url}}/account/">{{t "Go to your account"}}</a></p>
    {{else}}
      <form class="members-form" data-members-form="signin" aria-label="{{t "Sign in"}}">
        <div class="form-group">
          <label class="form-label" for="signin-email">{{t "Email"}}</label>
          <input class="form-input" id="signin-email" data-members-email type="email" autocomplete="email" placeholder="you@example.com" required />
        </div>
        <button class="btn btn-primary" type="submit">{{t "Sign in"}}</button>
        <div class="newsletter-success" data-members-success style="display:none; margin-top: var(--space-2);">
          <strong>{{t "Check your inbox"}}</strong><br>
          {{t "We've sent you a sign in link."}}
        </div>
        <div class="newsletter-error" data-members-error style="display:none; margin-top: var(--space-2);">
          {{t "Something went wrong. Please try again."}}
        </div>
      </form>
      <p class="text-sm text-muted" style="margin-top: var(--space-3);">
        {{t "Don't have an account?"}} <a href="{{@site.url}}/signup/">{{t "Sign up"}}</a>
      </p>
    {{/if}}
  </article>
</div>
