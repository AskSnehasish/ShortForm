{{!< default}}

<div class="container">
  <article class="post-content" style="max-width: 480px; margin: 0 auto;">
    <h1>{{t "Subscribe"}}</h1>
    <p class="text-muted" style="margin-bottom: var(--space-4);">{{t "Choose a plan to get access to premium content."}}</p>

    {{#if @member}}
      <p>{{t "You are already a member."}} <a href="{{@site.url}}/account/">{{t "Manage your subscription"}}</a></p>
    {{else}}
      <form class="members-form" data-members-form="subscribe" aria-label="{{t "Subscribe"}}">
        <div class="form-group">
          <label class="form-label" for="subscribe-email">{{t "Email"}}</label>
          <input class="form-input" id="subscribe-email" data-members-email type="email" autocomplete="email" placeholder="you@example.com" required />
        </div>
        <button class="btn btn-primary" type="submit">{{t "Subscribe"}}</button>
        <div class="newsletter-success" data-members-success style="display:none; margin-top: var(--space-2);">
          <strong>{{t "Check your inbox"}}</strong><br>
          {{t "We've sent you a confirmation email."}}
        </div>
        <div class="newsletter-error" data-members-error style="display:none; margin-top: var(--space-2);">
          {{t "Something went wrong. Please try again."}}
        </div>
      </form>
      <p class="text-sm text-muted" style="margin-top: var(--space-3);">
        {{t "Already have an account?"}} <a href="{{@site.url}}/signin/">{{t "Sign in"}}</a>
      </p>
    {{/if}}
  </article>
</div>
