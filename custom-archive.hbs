{{!< default}}

<div class="archive-container">
  <header class="archive-header">
    <h1 class="archive-heading">{{t "Archive"}}</h1>
  </header>

  {{#get "posts" limit="all" order="published_at desc"}}
    {{#if posts}}
      <div class="archive-list" data-archive>
        {{#foreach posts}}
          <article class="archive-post reveal" data-year="{{date format="YYYY"}}" data-month="{{date format="YYYY-MM"}}" data-date="{{date format="YYYY-MM-DD"}}">
            <time class="archive-time" datetime="{{date format="YYYY-MM-DDTHH:mm:ss.SSSZ"}}">{{date format="h:mm A"}}</time>
            <a class="archive-post-title" href="{{url}}">{{title}}</a>
          </article>
        {{/foreach}}
      </div>
    {{else}}
      <p class="archive-empty">{{t "No posts found."}}</p>
    {{/if}}
  {{/get}}
</div>

<script>
(function() {
  var list = document.querySelector('[data-archive]');
  if (!list) return;
  var postNodes = list.querySelectorAll('.archive-post');
  if (!postNodes.length) return;
  var posts = Array.prototype.slice.call(postNodes);
  var months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  var monthsShort = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

  var years = [];
  var yearMap = {};
  posts.forEach(function(p) {
    var y = p.getAttribute('data-year');
    if (!yearMap[y]) {
      yearMap[y] = true;
      years.push(y);
    }
  });

  var activeYear = years[0];

  var nav = document.createElement('nav');
  nav.className = 'tag-year-nav';
  years.forEach(function(y) {
    var a = document.createElement('a');
    a.href = '#';
    a.textContent = y;
    a.className = 'tag-year-link';
    if (y === activeYear) a.classList.add('active');
    a.addEventListener('click', function(e) {
      e.preventDefault();
      if (a.classList.contains('active')) return;
      nav.querySelectorAll('.tag-year-link').forEach(function(l) { l.classList.remove('active'); });
      a.classList.add('active');
      activeYear = y;
      renderPosts(y);
    });
    nav.appendChild(a);
  });
  list.parentNode.insertBefore(nav, list);

  function renderPosts(year) {
    var headings = list.querySelectorAll('.archive-year, .archive-month, .archive-date');
    for (var h = headings.length - 1; h >= 0; h--) {
      headings[h].remove();
    }
    var lastYear, lastMonth, lastDate;
    posts.forEach(function(post) {
      var py = post.getAttribute('data-year');
      var pm = post.getAttribute('data-month');
      var pd = post.getAttribute('data-date');
      if (py === year) {
        post.style.display = '';
        if (py !== lastYear) {
          var yh = document.createElement('h2');
          yh.className = 'archive-year';
          yh.textContent = py;
          list.insertBefore(yh, post);
          lastYear = py;
        }
        if (pm !== lastMonth) {
          var mh = document.createElement('h3');
          mh.className = 'archive-month';
          mh.textContent = months[parseInt(pm.split('-')[1], 10) - 1];
          list.insertBefore(mh, post);
          lastMonth = pm;
        }
        if (pd !== lastDate) {
          var dh = document.createElement('h4');
          dh.className = 'archive-date';
          var parts = pd.split('-');
          dh.innerHTML = '<time datetime="' + pd + '">' + monthsShort[parseInt(parts[1], 10) - 1] + ' ' + parseInt(parts[2], 10) + ', ' + parts[0] + '</time>';
          list.insertBefore(dh, post);
          lastDate = pd;
        }
      } else {
        post.style.display = 'none';
      }
    });
  }

  renderPosts(activeYear);
})();
</script>
